# if unable to use an env var, turbo may override them
# https://turbo.build/repo/docs/crafting-your-repository/using-environment-variables

# NODE
NODE_ENV="development"

# RESEND
RESEND_API_KEY=""


# GOOGLE OAUTH
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# TURSO AUTH
TURSO_AUTH_DB_TOKEN=""
TURSO_AUTH_DB_URL=""

# SAMPLE
SAMPLE_ENV_VAR="sample_value"
