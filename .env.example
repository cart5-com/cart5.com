# if unable to use an env var, turbo may override them
# https://turbo.build/repo/docs/crafting-your-repository/using-environment-variables

# NODE
NODE_ENV="development"

# RESEND
RESEND_API_KEY=""


# GOOGLE OAUTH
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/login/google/callback"

# TURSO AUTH
TURSO_AUTH_DB_TOKEN=""
TURSO_AUTH_DB_URL=""

# ```bash
# openssl rand --base64 16
# ```
ENCRYPTION_KEY=""
JWT_SECRET=""

# SAMPLE
SAMPLE_ENV_VAR="sample_value"
