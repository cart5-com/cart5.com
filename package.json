{
  "name": "cart5.com",
  "private": true,
  "scripts": {
    "dev": "pnpm format && turbo dev --ui=stream",
    "build": "dotenv -e ../../.env.production -- bash -c 'turbo run build'",
    "start": "dotenv -e ../../.env.production -- bash -c 'turbo run start'",
    "format": "prettier --write \"**/*.{ts,tsx,md,astro,vue}\""
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prettier-plugin-vue": "^1.1.6",
    "turbo": "^2.3.0",
    "typescript": "5.6.3",
    "wait-on": "^8.0.1"
  },
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20"
  }
}
