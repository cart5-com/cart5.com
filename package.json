{
  "name": "cart5.com",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "prod:generate:sql": "cd apps/auth-api-hono && pnpm prod:generate:sql",
    "prod:migrate": "cd apps/auth-api-hono && pnpm prod:migrate",
    "format": "prettier --write \"**/*.{ts,tsx,md,astro,vue,css}\""
  },
  "dependencies": {
    "@types/node": "^22.10.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prettier-plugin-vue": "^1.1.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}