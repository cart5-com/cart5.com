{
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 80,
  "editor.wrappingIndent": "same",
  "html.format.wrapAttributes": "force-aligned",
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar",
    "editor.formatOnSave": true
  },
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.formatOnSaveMode": "file",
  "typescript.tsserver.experimental.enableProjectDiagnostics": false, // filter: !**/node_modules/**
  "css.validate": false,
  "tailwindCSS.includeLanguages": {
    "vue": "html",
    "javascript": "javascript"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "tsconfig.json": "tsconfig.*.json, env.d.ts",
    "vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*",
    "package.json": "package-lock.json, pnpm*, .yarnrc*, yarn*, .eslint*, eslint*, .prettier*, prettier*, .editorconfig, nixpacks.toml, license.md, .gitignore, .cursorignore",
    ".env": ".env*"
  }
}