{
	debug
	on_demand_tls {
		ask http://localhost:5555/
		interval 2m
		burst 5
	}
}

# TODO: validate domain before SSL challenge 
# allow all for now
http://localhost:5555 {
	respond 200
}

(auth-api-hono-proxy) {
	handle_path /__p_auth/* {
		#auth-api-hono
		reverse_proxy http://localhost:3000
	}
}

# redirect to HTTPS
:80 {
	redir https://{host}{uri}
}

https://auth.{$PUBLIC_DOMAIN_NAME} {
	tls {
		on_demand
	}
	import auth-api-hono-proxy
	handle_path /* {
		#auth-frontend-vue
		reverse_proxy http://localhost:3001
	}
}

:443 {
	tls {
		on_demand
	}
	import auth-api-hono-proxy
	handle_path /* {
		#web-store-ssr-astro
		reverse_proxy http://localhost:3002
	}
}
