(api-hono-proxy) {
	handle_path /__p_api/* {
		#api-hono
		reverse_proxy http://127.0.0.1:3000
	}
}

# redirect to HTTPS
:80 {
	redir https://{host}{uri}
}

https://auth.{$PUBLIC_DOMAIN_NAME} {
	tls internal
	import api-hono-proxy
	handle_path /* {
		#auth-frontend-vue
		reverse_proxy http://127.0.0.1:3001
	}
}

https://dashboard.{$PUBLIC_DOMAIN_NAME} {
	tls internal
	import api-hono-proxy
	handle_path /* {
		#auth-frontend-vue
		reverse_proxy http://127.0.0.1:3004
	}
}

sample-store-1.com,
sample-store-2.com,
unknown-store.com,
:443 {
	tls internal
	import api-hono-proxy
	handle_path /* {
		#web-store-ssr-astro
		reverse_proxy http://127.0.0.1:3002
	}
}
