{
  "name": "web-store-ssr-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenvx run -- astro dev --port 3002",
    "build": "dotenvx run -- astro check && dotenvx run -- astro build",
    "start": "dotenvx run --env HOST=0.0.0.0 --env PORT=3002 -- node ./dist/server/entry.mjs"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.32.0",
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^9.0.0",
    "astro": "^5.0.2",
    "lib": "workspace:*",
    "typescript": "^5.7.2"
  }
}