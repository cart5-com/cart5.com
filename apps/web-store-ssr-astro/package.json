{
  "name": "web-store-ssr-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenv -e ../../.env -- bash -c 'astro dev --port 3002'",
    "build": "astro check && astro build",
    "preview": "astro preview --port 3002",
    "astro": "astro",
    "start": "pm2 reload ./ecosystem.config.cjs -i 0 --update-env && pm2 save"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^9.0.0",
    "astro": "^5.0.2",
    "lib": "workspace:*",
    "dotenv": "16.4.5",
    "typescript": "^5.7.2"
  }
}