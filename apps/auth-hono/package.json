		"hono": "^4.6.10",
		"lib": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.9.0",
		"drizzle-kit": "^0.28.1",
		"esbuild": "^0.24.0",
		"tsx": "^4.19.2"
