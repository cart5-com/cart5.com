---
import UserPagesLayout from "@root/layouts/UserPagesLayout.astro";
import Logo from "@root/components/Logo.astro";
import { Card, CardContent } from "@/components/ui/card";
import LogoutButton from "@root/components/LogoutButton.astro";
import UserDetails from "@root/components/vue/UserDetails.vue";
import UserSecuritySettings from "@root/components/vue/UserSecuritySettings.vue";
import { Separator } from "@/components/ui/separator";
---

<UserPagesLayout>
	<Logo />
	<Card>
		<CardContent class="space-y-6">
			<h1 class="my-6 text-2xl font-bold">Settings</h1>
			<UserDetails client:only="vue" />
			<LogoutButton />
			<Separator class="my-10" />
			<UserSecuritySettings class="my-10" client:only="vue" />
		</CardContent>
	</Card>
</UserPagesLayout>
